# ============================================================================
#  sdkconfig.defaults — variant B (jobs-esp). Pure ESP-IDF 5.3.x.
#  Same anti-brick / TLS settings as variant C; only the OTA transport changed.
# ============================================================================

# --- Flash size + custom partition table (identical to C for apples-to-apples)
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# --- Anti-brick OTA rollback ------------------------------------------------
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y
CONFIG_BOOTLOADER_WDT_ENABLE=y

# --- mbedTLS threading ------------------------------------------------------
# esp-mqtt (its own task) and esp_https_ota (download task) each open a TLS
# session; the IDF 5.3 default (THREADING_ALT=y) races their shared mbedTLS
# globals. Force pthread-backed locking (same hazard as C, different engines).
CONFIG_MBEDTLS_THREADING_C=y
CONFIG_MBEDTLS_THREADING_ALT=n
CONFIG_MBEDTLS_THREADING_PTHREAD=y
CONFIG_PTHREAD_TASK_STACK_SIZE_DEFAULT=8192

# --- TLS buffer tuning ------------------------------------------------------
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y
CONFIG_MBEDTLS_SSL_VARIABLE_BUFFER_LENGTH=y

# --- Task watchdog: armed manually during the self-test ---------------------
CONFIG_ESP_TASK_WDT_INIT=n

# --- Stacks / main task -----------------------------------------------------
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_FREERTOS_HZ=1000

# --- Logging ----------------------------------------------------------------
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_MAXIMUM_LEVEL_DEBUG=y

# --- Coredump to flash ------------------------------------------------------
CONFIG_ESP_COREDUMP_ENABLE_TO_FLASH=y
CONFIG_ESP_COREDUMP_DATA_FORMAT_ELF=y

# --- Newlib nano printf -----------------------------------------------------
CONFIG_NEWLIB_NANO_FORMAT=y
