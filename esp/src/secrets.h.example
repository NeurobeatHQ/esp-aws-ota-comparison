/*
 * secrets.h.example — copy to secrets.h (which is .gitignored) and fill in.
 *
 *   cp src/secrets.h.example src/secrets.h
 *
 * The device cert + private key + Thing name are NOT here — they are read at runtime
 * from the esp_secure_cert partition (provision-secure-cert.sh). See esp/README.md.
 */
#ifndef SECRETS_H
#define SECRETS_H

/* Wi-Fi (2.4 GHz — the ESP32-S3 has no 5 GHz radio). */
#define WIFI_SSID        "your-2g4-ssid"
#define WIFI_PASSWORD    "your-wifi-password"

/* AWS IoT Core ATS data endpoint for your account/region:
 *   aws iot describe-endpoint --endpoint-type iot:Data-ATS --query endpointAddress --output text
 */
#define AWS_IOT_ENDPOINT "xxxxxxxxxxxxxx-ats.iot.us-east-1.amazonaws.com"

#endif /* SECRETS_H */
